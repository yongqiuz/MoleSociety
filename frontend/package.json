{
  "name": "mole-society",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite --host 127.0.0.1 --port 4173",
    "dev:backend": "cd ../backend && mvn spring-boot:run",
    "dev:all": "concurrently --names \"backend,frontend\" --prefix \"[{name}]\" --prefix-colors \"magenta,cyan\" --kill-others --kill-others-on-fail \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "vue-tsc --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "ethers": "^6.13.5",
    "lucide-vue-next": "^1.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vue-tsc": "^2.1.10"
  }
}
